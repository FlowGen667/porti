---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout lang="pt">
  <main class="nf">
    <div class="nf-bg" aria-hidden="true"></div>
    <p class="code gradient-text">404</p>
    <h1>Página não encontrada · Page not found · Página no encontrada</h1>
    <p class="sub">O endereço que você procura não existe ou foi movido.</p>
    <a class="btn btn-primary" href="/">
      <Icon name="arrow" />Voltar ao início
    </a>
  </main>
</Layout>

<style>
  .nf {
    min-height: 100vh;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 1rem;
    padding: 2rem;
    position: relative;
  }
  .nf-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(ellipse 60% 50% at 50% 30%, var(--glow), transparent 70%);
    opacity: 0.5;
  }
  .code {
    font-family: var(--font-mono);
    font-size: clamp(5rem, 18vw, 11rem);
    font-weight: 800;
    line-height: 1;
  }
  .nf h1 {
    font-size: clamp(1.1rem, 3vw, 1.6rem);
  }
  .sub {
    color: var(--text-soft);
  }
  .btn {
    margin-top: 1rem;
    flex-direction: row-reverse;
    justify-self: center;
  }
  .btn svg {
    transform: rotate(180deg);
  }
</style>
