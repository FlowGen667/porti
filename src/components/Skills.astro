---
import Icon from './Icon.astro';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { skillGroups } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const groupIcon = {
  frontend: 'spark',
  backend: 'bot',
  platform: 'cloud',
  craft: 'gauge',
} as const;
---

<section class="section" id="skills">
  <div class="container">
    <header class="head" data-reveal>
      <p class="eyebrow">{t('skills.eyebrow')}</p>
      <h2 class="section-title">{t('skills.title')}</h2>
      <p class="section-subtitle">{t('skills.subtitle')}</p>
    </header>

    <div class="grid">
      {skillGroups.map((g, i) => (
        <article class="card" data-reveal style={`--reveal-delay:${i * 70}ms`}>
          <div class="card-icon">
            <Icon name={groupIcon[g.id]} />
          </div>
          <h3 class="card-title">{g.label[lang]}</h3>
          <ul class="tags">
            {g.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .head {
    max-width: 60ch;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 1.2rem;
  }
  .card {
    padding: 1.8rem;
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    background: var(--surface);
    position: relative;
    overflow: hidden;
    transition: transform var(--t-fast) var(--ease), border-color var(--t-fast),
      box-shadow var(--t-fast);
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(420px circle at var(--mx, 50%) var(--my, 0%), var(--glow), transparent 60%);
    opacity: 0;
    transition: opacity var(--t-med);
    pointer-events: none;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow);
  }
  .card:hover::before {
    opacity: 0.4;
  }
  .card-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: var(--r-md);
    background: color-mix(in srgb, var(--violet) 16%, transparent);
    color: var(--violet);
    margin-bottom: 1.2rem;
  }
  :root[data-theme='dark'] .card-icon {
    color: #b3a4ff;
  }
  .card-icon svg {
    width: 22px;
    height: 22px;
  }
  .card-title {
    font-size: 1.15rem;
    margin-bottom: 1rem;
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tags li {
    padding: 0.35rem 0.75rem;
    border-radius: var(--r-full);
    background: var(--surface-2);
    border: 1px solid var(--border);
    font-size: 0.82rem;
    color: var(--text-soft);
    font-family: var(--font-mono);
  }
</style>

<script>
  // subtle pointer-tracking glow on cards
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll('#skills .card').forEach((card) => {
      card.addEventListener('pointermove', (e) => {
        const r = (card as HTMLElement).getBoundingClientRect();
        (card as HTMLElement).style.setProperty('--mx', `${e.clientX - r.left}px`);
        (card as HTMLElement).style.setProperty('--my', `${e.clientY - r.top}px`);
      });
    });
  }
</script>
