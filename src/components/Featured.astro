---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { featuredProject } from '../data/content';
import synapseShot from '../assets/projects/synapse.png';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const metrics = [
  { label: 'Performance', value: 'Core Web Vitals', icon: 'gauge' as const },
  { label: 'SEO', value: 'On-page audit', icon: 'spark' as const },
  { label: 'A11y', value: 'WCAG checks', icon: 'check' as const },
  { label: 'UX', value: 'Best practices', icon: 'bot' as const },
];
---

<section class="section" id="featured">
  <div class="container">
    <div class="featured" data-reveal>
      <div class="featured-glow" aria-hidden="true"></div>

      <div class="featured-content">
        <p class="eyebrow">{t('featured.eyebrow')}</p>
        <h2 class="featured-title">{t('featured.title')}</h2>
        <span class="featured-badge">{t('featured.tag')}</span>
        <p class="featured-desc">{t('featured.description')}</p>

        <ul class="metrics">
          {metrics.map((m) => (
            <li>
              <span class="metric-icon"><Icon name={m.icon} /></span>
              <span class="metric-text">
                <strong>{m.label}</strong>
                <small>{m.value}</small>
              </span>
            </li>
          ))}
        </ul>

        <a class="btn btn-primary" href={featuredProject.url} target="_blank" rel="noopener">
          {t('featured.cta')}<Icon name="arrow-up-right" />
        </a>
      </div>

      <a
        class="featured-media"
        href={featuredProject.url}
        target="_blank"
        rel="noopener"
        aria-label={t('featured.title')}
      >
        <div class="browser-bar" aria-hidden="true">
          <span></span><span></span><span></span>
          <i>synapse.flowgensolutions.com.br</i>
        </div>
        <Image
          src={synapseShot}
          alt={`${t('featured.title')} — ${t('featured.description')}`}
          width={1200}
          height={588}
          widths={[600, 1200]}
          sizes="(max-width: 900px) 100vw, 560px"
          loading="lazy"
          class="featured-shot"
        />
      </a>
    </div>
  </div>
</section>

<style>
  .featured {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding: clamp(2rem, 5vw, 3.5rem);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    background: linear-gradient(160deg, var(--surface), var(--bg-soft));
    overflow: hidden;
  }
  .featured-glow {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--glow), transparent 70%);
    top: -120px;
    right: -80px;
    filter: blur(60px);
    opacity: 0.5;
    pointer-events: none;
  }
  .featured-content {
    position: relative;
    z-index: 1;
  }
  .featured-title {
    font-size: clamp(1.7rem, 3.5vw, 2.6rem);
    margin-bottom: 0.7rem;
  }
  .featured-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--r-full);
    border: 1px solid var(--border-strong);
    color: var(--text-soft);
    margin-bottom: 1.2rem;
  }
  .featured-desc {
    color: var(--text-soft);
    font-size: 1.05rem;
    max-width: 48ch;
  }
  .metrics {
    list-style: none;
    padding: 0;
    margin: 1.8rem 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }
  .metrics li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .metric-icon {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--cyan) 14%, transparent);
    color: var(--cyan);
  }
  .metric-icon svg {
    width: 18px;
    height: 18px;
  }
  .metric-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .metric-text strong {
    font-size: 0.92rem;
  }
  .metric-text small {
    color: var(--text-mute);
    font-size: 0.78rem;
  }

  .featured-media {
    position: relative;
    z-index: 1;
    display: block;
    border-radius: var(--r-md);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow);
    transition: transform var(--t-med) var(--ease);
  }
  .featured-media:hover {
    transform: translateY(-4px) scale(1.01);
  }
  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }
  .browser-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .browser-bar i {
    margin-left: 0.6rem;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-mute);
  }
  .featured-shot {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 860px) {
    .featured {
      grid-template-columns: 1fr;
    }
    .featured-media {
      order: -1;
    }
  }
  @media (max-width: 440px) {
    .metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
