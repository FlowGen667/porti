---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from './Icon.astro';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { projects, projectTagLabels, type ProjectTag } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// eager-glob the screenshots so Astro optimizes each to webp
const shots = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/projects/*.png',
  { eager: true }
);
const imageFor = (id: string) => shots[`../assets/projects/${id}.png`]?.default;

// build filter list from tags actually used
const usedTags = [...new Set(projects.flatMap((p) => p.tags))] as ProjectTag[];
const filters: { value: 'all' | ProjectTag; label: string }[] = [
  { value: 'all', label: t('projects.all') },
  ...usedTags.map((tag) => ({ value: tag, label: projectTagLabels[tag][lang] })),
];

const host = (url: string) => new URL(url).host.replace('www.', '');
---

<section class="section" id="projects">
  <div class="container">
    <header class="head" data-reveal>
      <p class="eyebrow">{t('projects.eyebrow')}</p>
      <h2 class="section-title">{t('projects.title')}</h2>
      <p class="section-subtitle">{t('projects.subtitle')}</p>
    </header>

    <div class="filters" role="tablist" aria-label={t('projects.title')} data-reveal>
      {filters.map((f, i) => (
        <button
          class:list={['filter', { active: f.value === 'all' }]}
          data-filter={f.value}
          role="tab"
          aria-selected={f.value === 'all'}
        >
          {f.label}
        </button>
      ))}
    </div>

    <div class="grid" data-grid>
      {projects.map((p, i) => {
        const img = imageFor(p.id);
        return (
          <article
            class="project"
            data-tags={p.tags.join(' ')}
            data-reveal
            style={`--reveal-delay:${(i % 3) * 80}ms`}
          >
            <a class="project-media" href={p.url} target="_blank" rel="noopener" aria-label={p.title}>
              {img && (
                <Image
                  src={img}
                  alt={`${p.title} — ${p.description[lang]}`}
                  width={760}
                  height={475}
                  widths={[380, 760]}
                  sizes="(max-width: 700px) 100vw, 380px"
                  loading="lazy"
                  class="shot"
                />
              )}
              <span class="media-overlay">
                <Icon name="arrow-up-right" />
              </span>
            </a>
            <div class="project-body">
              <div class="project-tags">
                {p.tags.map((tag) => (
                  <span class="ptag">{projectTagLabels[tag][lang]}</span>
                ))}
              </div>
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.description[lang]}</p>
              <a class="project-link" href={p.url} target="_blank" rel="noopener">
                <span class="host">{host(p.url)}</span>
                <span class="visit">{t('projects.visit')}<Icon name="arrow" /></span>
              </a>
            </div>
          </article>
        );
      })}
    </div>
    <p class="empty" data-empty hidden>{t('projects.empty')}</p>
  </div>
</section>

<style>
  .head {
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.4rem;
  }
  .filter {
    padding: 0.55rem 1.1rem;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-soft);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
  }
  .filter:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }
  .filter.active {
    color: #0a0a0f;
    background: var(--grad);
    border-color: transparent;
    font-weight: 600;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
    gap: 1.4rem;
  }
  .project {
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--t-fast) var(--ease), border-color var(--t-fast),
      box-shadow var(--t-fast), opacity var(--t-med), filter var(--t-med);
  }
  .project:hover {
    transform: translateY(-5px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow);
  }
  .project[hidden] {
    display: none;
  }
  .project-media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }
  .shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform var(--t-med) var(--ease);
  }
  .project:hover .shot {
    transform: scale(1.05);
  }
  .media-overlay {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-full);
    background: color-mix(in srgb, var(--bg) 65%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-strong);
    color: var(--text);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity var(--t-fast), transform var(--t-fast);
  }
  .project:hover .media-overlay {
    opacity: 1;
    transform: none;
  }
  .media-overlay svg {
    width: 18px;
    height: 18px;
  }

  .project-body {
    padding: 1.3rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }
  .ptag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: var(--r-full);
    color: var(--cyan);
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
  }
  .project-title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .project-desc {
    color: var(--text-soft);
    font-size: 0.95rem;
    flex: 1;
  }
  .project-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
  }
  .host {
    color: var(--text-mute);
    font-family: var(--font-mono);
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text);
    font-weight: 600;
    transition: gap var(--t-fast);
  }
  .visit svg {
    width: 15px;
    height: 15px;
  }
  .project-link:hover .visit {
    gap: 0.6rem;
    color: var(--cyan);
  }
  .empty {
    text-align: center;
    color: var(--text-mute);
    padding: 2rem 0;
  }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('#projects .filter');
  const cards = document.querySelectorAll<HTMLElement>('#projects .project');
  const empty = document.querySelector<HTMLElement>('#projects [data-empty]');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.filter!;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('active', on);
        b.setAttribute('aria-selected', String(on));
      });
      let visible = 0;
      cards.forEach((card) => {
        const tags = (card.dataset.tags || '').split(' ');
        const show = val === 'all' || tags.includes(val);
        card.hidden = !show;
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });
</script>
