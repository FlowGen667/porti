---
import Icon from './Icon.astro';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { profile } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = 2025;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-mark gradient-text">GM</span>
      <div>
        <strong>{profile.name}</strong>
        <small>{t('hero.eyebrow')}</small>
      </div>
    </div>

    <div class="footer-social">
      <a href={profile.social.github} target="_blank" rel="noopener" aria-label="GitHub">
        <Icon name="github" />
      </a>
      <a href={profile.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
        <Icon name="instagram" />
      </a>
      <a href={profile.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
        <Icon name="whatsapp" />
      </a>
      <a href={`mailto:${profile.email}`} aria-label="Email">
        <Icon name="mail" />
      </a>
    </div>

    <a class="to-top" href="#top" aria-label={t('footer.backToTop')}>
      <Icon name="up" />
    </a>
  </div>

  <div class="container footer-meta">
    <span>© {year} {profile.name}. {t('footer.rights')}</span>
    <span>{t('footer.built')}</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 2.5rem 2rem;
    margin-top: 2rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .brand-mark {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: var(--font-mono);
  }
  .footer-brand div {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .footer-brand small {
    color: var(--text-mute);
    font-size: 0.82rem;
  }
  .footer-social {
    display: flex;
    gap: 0.5rem;
    margin-left: auto;
  }
  .footer-social a {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition: color var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
  }
  .footer-social a:hover {
    color: var(--text);
    border-color: var(--violet);
    transform: translateY(-2px);
  }
  .footer-social svg {
    width: 18px;
    height: 18px;
  }
  .to-top {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: var(--r-full);
    background: var(--grad);
    color: #0a0a0f;
    transition: transform var(--t-fast);
  }
  .to-top:hover {
    transform: translateY(-3px);
  }
  .to-top svg {
    width: 18px;
    height: 18px;
  }
  .footer-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--border);
    color: var(--text-mute);
    font-size: 0.82rem;
  }
</style>
