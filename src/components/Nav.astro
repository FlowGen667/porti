---
import Icon from './Icon.astro';
import { languages, type Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';
import { profile } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: '#skills', label: t('nav.skills') },
  { href: '#projects', label: t('nav.projects') },
  { href: '#about', label: t('nav.about') },
  { href: '#contact', label: t('nav.contact') },
];
const langList = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  label: languages[code],
  href: localizePath('/', code),
  active: code === lang,
}));
---

<header class="nav" id="nav">
  <div class="container nav-inner">
    <a class="brand" href={localizePath('/', lang)} aria-label={profile.name}>
      <span class="brand-mark gradient-text">GM</span>
      <span class="brand-name">{profile.name}</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-actions">
      <!-- Language switcher -->
      <div class="lang" data-lang>
        <button class="lang-btn" aria-haspopup="true" aria-expanded="false" aria-label={t('nav.lang')}>
          <Icon name="globe" class="ic" />
          <span>{lang.toUpperCase()}</span>
          <Icon name="chevron" class="ic-sm" />
        </button>
        <ul class="lang-menu" role="menu">
          {langList.map((l) => (
            <li role="none">
              <a role="menuitem" href={l.href} hreflang={l.code} class={l.active ? 'is-active' : ''}>
                {l.label}
                {l.active && <Icon name="check" class="ic-sm" />}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Theme toggle -->
      <button class="theme-btn" data-theme-toggle aria-label={t('nav.theme')}>
        <Icon name="sun" class="ic ic-sun" />
        <Icon name="moon" class="ic ic-moon" />
      </button>

      <a class="btn btn-primary nav-cta" href="#contact">{t('nav.cta')}</a>

      <!-- Mobile menu -->
      <button class="menu-btn" data-menu-toggle aria-label={t('nav.menu')} aria-expanded="false">
        <Icon name="menu" class="ic ic-open" />
        <Icon name="close" class="ic ic-close" />
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" data-drawer>
    <nav aria-label="Mobile">
      {links.map((l) => <a href={l.href} data-drawer-link>{l.label}</a>)}
      <a href="#contact" class="btn btn-primary" data-drawer-link>{t('nav.cta')}</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background var(--t-med) var(--ease), border-color var(--t-med) var(--ease),
      backdrop-filter var(--t-med) var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(14px) saturate(160%);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .brand-mark {
    font-size: 1.35rem;
    font-weight: 800;
    font-family: var(--font-mono);
  }
  .brand-name {
    font-size: 0.98rem;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav-links a {
    font-size: 0.92rem;
    color: var(--text-soft);
    transition: color var(--t-fast) var(--ease);
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 2px;
    background: var(--grad);
    transition: width var(--t-fast) var(--ease);
  }
  .nav-links a:hover {
    color: var(--text);
  }
  .nav-links a:hover::after {
    width: 100%;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ic {
    width: 18px;
    height: 18px;
  }
  .ic-sm {
    width: 14px;
    height: 14px;
    opacity: 0.7;
  }

  /* language */
  .lang {
    position: relative;
  }
  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.7rem;
    border-radius: var(--r-full);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-soft);
    border: 1px solid var(--border);
    transition: color var(--t-fast), border-color var(--t-fast);
  }
  .lang-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }
  .lang-menu {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 168px;
    list-style: none;
    padding: 0.4rem;
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    box-shadow: var(--shadow);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
  }
  .lang[data-open] .lang-menu {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .lang-menu a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.7rem;
    border-radius: var(--r-sm);
    font-size: 0.9rem;
    color: var(--text-soft);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .lang-menu a:hover {
    background: var(--surface-2);
    color: var(--text);
  }
  .lang-menu a.is-active {
    color: var(--cyan);
  }

  /* theme */
  .theme-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition: color var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
  }
  .theme-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
    transform: rotate(12deg);
  }
  .theme-btn .ic {
    grid-area: 1 / 1;
    transition: opacity var(--t-fast), transform var(--t-fast);
  }
  :root[data-theme='dark'] .ic-sun {
    opacity: 0;
    transform: scale(0.4) rotate(-90deg);
  }
  :root[data-theme='light'] .ic-moon {
    opacity: 0;
    transform: scale(0.4) rotate(90deg);
  }

  .menu-btn {
    display: none;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    color: var(--text);
  }
  .menu-btn .ic {
    grid-area: 1 / 1;
    transition: opacity var(--t-fast), transform var(--t-fast);
  }
  .menu-btn .ic-close {
    opacity: 0;
    transform: scale(0.5);
  }
  .nav.menu-open .menu-btn .ic-open {
    opacity: 0;
    transform: scale(0.5);
  }
  .nav.menu-open .menu-btn .ic-close {
    opacity: 1;
    transform: none;
  }

  .mobile-drawer {
    position: fixed;
    inset: var(--nav-h) 0 auto 0;
    background: color-mix(in srgb, var(--bg) 95%, transparent);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--t-med) var(--ease);
  }
  .nav.menu-open + .mobile-drawer,
  .mobile-drawer.open {
    max-height: 380px;
  }
  .mobile-drawer nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.2rem var(--gutter) 1.8rem;
  }
  .mobile-drawer a {
    padding: 0.85rem 0.4rem;
    font-size: 1.05rem;
    color: var(--text-soft);
    border-bottom: 1px solid var(--border);
  }
  .mobile-drawer a.btn {
    justify-content: center;
    color: #0a0a0f;
    border: none;
    margin-top: 0.6rem;
  }

  @media (max-width: 880px) {
    .nav-links,
    .nav-cta {
      display: none;
    }
    .menu-btn {
      display: grid;
    }
  }
  @media (max-width: 480px) {
    .brand-name {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  // scrolled state
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // theme toggle
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try {
      localStorage.setItem('theme', next);
    } catch (e) {}
  });

  // language dropdown
  const lang = document.querySelector('[data-lang]');
  const langBtn = lang?.querySelector('.lang-btn');
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = lang?.toggleAttribute('data-open');
    langBtn.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', () => {
    lang?.removeAttribute('data-open');
    langBtn?.setAttribute('aria-expanded', 'false');
  });

  // mobile menu
  const menuBtn = document.querySelector('[data-menu-toggle]');
  menuBtn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('menu-open');
    menuBtn.setAttribute('aria-expanded', String(open));
  });
  document.querySelectorAll('[data-drawer-link]').forEach((l) =>
    l.addEventListener('click', () => {
      nav?.classList.remove('menu-open');
      menuBtn?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
